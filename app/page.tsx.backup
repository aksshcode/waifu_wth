"use client"

import { useState, useEffect } from "react"
import Image from "next/image";
import { Card } from "@/components/ui/card"
import { HyperText } from "@/components/ui/hyper-text";
import RefreshBtn from "@/components/ui/refreshBtn"
import { motion } from "motion/react"

export default function Home() {
  const [imgUrl, setImgUrl] = useState("/placeholder.svg")
  const [imgName, setImgName] = useState("")
  const [imgDesc, setImgDesc] = useState("")

  useEffect(() => {
    fetch("https://nekos.best/api/v2/waifu")
      .then(r => {
        if (!r.ok) throw new Error(`HTTP ${r.status}`)
        return r.json()
      })
      .then(data => {
        const item = data.results?.[0]
        setImgUrl(item?.url ?? "/placeholder.svg")
        setImgName(item?.artist_name ?? "unknown")
        setImgDesc("")
      })
      .catch(e => console.error("Fetch failed:", e))
  }, [])

  return (
    <div className="flex pt-24 flex-col min-h-screen items-center bg-zinc-50 font-sans dark:bg-black">
      <Header />
      <motion.div
        initial={{ filter: "blur(8px)" }}
        animate={{ filter: "blur(0px)" }}
        transition={{ duration: 0.2 }}
        className="relative flex flex-col flex-1 w-full p-0 max-w-md scale-80 overflow-hidden">
        <Card className="relative flex-1 rounded-xl overflow-hidden">
          <Image
            src={imgUrl}
            alt="waifu image"
            fill
            className="object-cover"
            preload
          />
          <div className="absolute inset-0 bg-linear-to-t from-black/70 to-transparent pointer-events-none" />
        </Card>
        <div className="absolute m-2 left-0 right-0 bottom-0 flex flex-col">
          <span className="text-white text-4xl">{imgName}</span>
          <span className="text-gray-200">{imgDesc}
          </span>
        </div>
      </motion.div>
      <RefreshBtn />
      <Footer />
    </div>
  );
}

function Header() {
  return (
    <div className="w-full absolute top-0 left-0 h-6">
      <div className="p-4 outline-1 outline-red-400 m-2 rounded-xl" style={{ backgroundColor: "#111" }}>
        <HyperText className="text-md m-0 p-0">Waifu_WTF</HyperText>
      </div>
    </div>
  )
}
function Footer() {
  return (
    <div className="mt-24 w-full bottom-0 left-0 h-auto flex justify-center items-center">
      <div className="bg-gray-700 flex flex-col justify-center items-center w-full h-16">
        hello there!
        im a footer
      </div>
    </div>
  )
}
